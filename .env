# Google Maps API key — required by react-native-maps on Android/iOS
# Even when using custom tiles (Gebeta) with mapType="none", the SDK must initialise.
# Get a free key: https://console.cloud.google.com → Maps SDK for Android/iOS
EXPO_PUBLIC_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Gebeta Maps API key (Ethiopian maps — Addis Ababa coverage)
EXPO_PUBLIC_GEBETA_MAPS_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..XSFDReGameyiSV0kWSKOYaVmdXrNgj4VP2xrwj4yLtA

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://taxiapi.zmichael.click/api/v1
EXPO_PUBLIC_SOCKET_URL=http://taxiapi.zmichael.click
